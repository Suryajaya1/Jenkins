pipeline {
    agent {
        node {
            label 'roboshop' 
        } 
    }
    stages {
        stage('Build') {
            steps {
                script{
                    sh """
                    echo "building"
                    exit 1
                    """
                }
               
            }
        }
        stage('Test') {
            steps {
                script {
                    sh """
                    echo "Testing"
                    """
                }
            }
        }
        stage('Deploy') {
            steps {
                script {
                    sh """
                    echo "Deploying"
                    """
                }
            }
        }
    }

    post {
        always {
            echo "This will always run"
        }
        success {
            echo "This will run only if the pipeline is successful"
        }
        failure {
            echo "This will run only if the pipeline fails"
        }
    }
}